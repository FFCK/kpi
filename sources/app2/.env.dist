# KPI App2 - Environment Configuration
# Copy this file to .env.development, .env.preprod, and .env.production
# Then adjust the values for each environment

# BASE_URL - Leave empty, Traefik handles routing
BASE_URL=

# API2 Base URL (Symfony API)
# Development: https://kpi.localhost/api2
API_BASE_URL=

# Backend Base URL (legacy PHP)
# Development: https://kpi.localhost
BACKEND_BASE_URL=

# Matomo Analytics
# MATOMO_ENABLED: set to 'true' only in production
# MATOMO_URL: base URL of your Matomo instance (no trailing slash)
# MATOMO_SITE_ID: site ID as configured in Matomo (app2 = site 1)
MATOMO_ENABLED=false
MATOMO_URL=https://matomo.mondomaine.com
MATOMO_SITE_ID=1

# KPI Admin - Environment Configuration
# Copy this file to .env and adjust values for your environment

# Base URL for the application (used for routing)
BASE_URL=/admin2

# API2 Base URL (Symfony API)
API2_BASE_URL=https://kpi.localhost/api2

# Legacy backend Base URL (for PDF documents)
LEGACY_BASE_URL=https://kpi.localhost

# KPI App (app2) Base URL
APP2_BASE_URL=https://app.kpi.localhost

# Environment: 'development' | 'preprod' | 'production' (default: auto-detected from NODE_ENV)
# APP_ENV=preprod

# Matomo Analytics
# MATOMO_ENABLED: set to 'true' only in production
# MATOMO_URL: base URL of your Matomo instance (no trailing slash)
# MATOMO_SITE_ID: site ID as configured in Matomo (app4/admin = site 2)
MATOMO_ENABLED=false
MATOMO_URL=https://matomo.mondomaine.com
MATOMO_SITE_ID=2

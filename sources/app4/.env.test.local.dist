# Modèle pour les tests Playwright en dev local.
# Copie ce fichier en .env.test.local (gitignoré) puis renseigne les valeurs.
#   cp .env.test.local.dist .env.test.local

# Compte de connexion (email ou code utilisateur), profil <= 2 pour le pool arbitres.
TEST_USERNAME=
TEST_PASSWORD=

# API atteignable en HTTP (contourne le certificat auto-signé Traefik).
# kpi_php expose le port 80 du conteneur sur 8003 côté hôte.
TEST_API_BASE=http://localhost:8003/api2

# Serveur de dev Nuxt app4 (HTTP, hot reload).
TEST_APP_URL=http://localhost:3004/admin2
